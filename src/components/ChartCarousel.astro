---
const FEATURED_CHARTS = [
  {
    image: "/images/mtg-card-power/decade_cmc_3d.png",
    caption: "Magic card efficiency is accelerating — fast",
    alt: "3D bar chart of Magic: The Gathering card ability efficiency by CMC and release decade",
    href: "/blog/mtg-card-power/",
  },
  {
    image: "/images/mtg-card-power/color_cmc_heatmap.png",
    caption: "Mana cost predicts efficiency. Color barely does.",
    alt: "Heatmap of Magic: The Gathering ability efficiency by color identity and CMC",
    href: "/blog/mtg-card-power/",
  },
  {
    image: "/images/mtg-distributions/legendary_over_time.png",
    caption: "'Legendary' is a weakening rarity signal",
    alt: "Prevalence of legendary cards in Magic: The Gathering over time",
    href: "/blog/mtg-distributions/",
  },
  {
    image: "/images/skyrim-alchemy/ingredient_heatmap.png",
    caption: "Where Skyrim's top ingredients actually grow",
    alt: "Heatmap of ingredient yield rates across six Skyrim regions",
    href: "/blog/skyrim-alchemy/",
    objectPosition: "center top",
  },
  {
    image: "/images/mtg-distributions/complexity_creep.png",
    caption: "Magic cards are getting wordier",
    alt: "Growth in Magic: The Gathering card complexity over time",
    href: "/blog/mtg-distributions/",
  },
  {
    image: "/images/skyrim-alchemy/region_allocation.png",
    caption: "How each Skyrim build allocates its foraging budget",
    alt: "Stacked bar chart: foraging budget allocation by region for six Skyrim character builds",
    href: "/blog/skyrim-alchemy/",
  },
  {
    image: "/images/skyrim-alchemy/sensitivity_curve.png",
    caption: "Potion output vs. foraging hours, by build",
    alt: "Weighted potion output vs. foraging hours for three Skyrim builds",
    href: "/blog/skyrim-alchemy/",
  },
];
---

<section class="carousel-section">
  <div class="carousel-wrapper">
    <div class="carousel-track" id="carousel-track">
      {FEATURED_CHARTS.map((chart) => (
        <div class="carousel-card">
          <a href={chart.href} class="card-link">
            <div class="card-image-wrapper">
              <img
                src={chart.image}
                alt={chart.alt}
                style={chart.objectPosition ? `object-position: ${chart.objectPosition}` : undefined}
              />
            </div>
            <div class="card-footer">
              <span class="card-caption">{chart.caption}</span>
              <span class="read-more">Read more →</span>
            </div>
          </a>
        </div>
      ))}
    </div>
    <button class="carousel-btn prev" id="carousel-prev" aria-label="Previous chart">←</button>
    <button class="carousel-btn next" id="carousel-next" aria-label="Next chart">→</button>
  </div>
</section>

<style>
  .carousel-section {
    margin-bottom: 3em;
    padding-bottom: 2em;
    border-bottom: 1px solid var(--border);
  }

  .carousel-wrapper {
    position: relative;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 16px;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    /* right padding so the last card can scroll fully into view */
    padding-right: 4px;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-card {
    flex-shrink: 0;
    width: 460px;
    scroll-snap-align: start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .carousel-card:hover {
    border-color: rgba(47, 91, 79, 0.18);
    box-shadow: 0 2px 16px rgba(28, 26, 23, 0.06);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: var(--text);
  }

  .card-link:hover {
    background: none;
  }

  .card-image-wrapper {
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    border-radius: 0;
    display: block;
  }

  .card-footer {
    padding: 14px 20px 18px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1em;
  }

  .card-caption {
    font-size: 0.85em;
    color: var(--text);
    font-weight: 500;
    line-height: 1.45;
  }

  .read-more {
    font-size: 0.75em;
    color: var(--accent);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Arrow buttons */
  .carousel-btn {
    position: absolute;
    top: 120px; /* vertical center of the 240px image area */
    transform: translateY(-50%);
    width: 32px;
    height: 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 50%;
    cursor: pointer;
    font-size: 13px;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    box-shadow: 0 1px 4px rgba(28, 26, 23, 0.08);
    z-index: 2;
    opacity: 1;
  }

  .carousel-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .carousel-btn.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .carousel-btn.prev {
    left: 8px;
  }

  .carousel-btn.next {
    right: 8px;
  }
</style>

<script>
  const track = document.getElementById("carousel-track") as HTMLElement;
  const prevBtn = document.getElementById("carousel-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("carousel-next") as HTMLButtonElement;

  const STEP = 460 + 16; // card width + gap

  function updateButtons() {
    const atStart = track.scrollLeft <= 1;
    const atEnd = track.scrollLeft >= track.scrollWidth - track.clientWidth - 1;
    prevBtn.classList.toggle("hidden", atStart);
    nextBtn.classList.toggle("hidden", atEnd);
  }

  prevBtn.addEventListener("click", () => {
    track.scrollBy({ left: -STEP, behavior: "smooth" });
  });

  nextBtn.addEventListener("click", () => {
    track.scrollBy({ left: STEP, behavior: "smooth" });
  });

  track.addEventListener("scroll", updateButtons, { passive: true });
  updateButtons();
</script>
