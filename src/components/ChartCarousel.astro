---
const FEATURED_CHARTS = [
  {
    image: "/images/skyrim-alchemy/region_allocation.png",
    alt: "Bar chart: optimal foraging hours per region for six Skyrim character builds",
    href: "/blog/skyrim-alchemy/",
  },
  {
    image: "/images/skyrim-alchemy/ingredient_heatmap.png",
    alt: "Heatmap of ingredient yield rates across six Skyrim regions",
    href: "/blog/skyrim-alchemy/",
    objectPosition: "center top",
  },
  {
    image: "/images/skyrim-alchemy/sensitivity_curve.png",
    alt: "Line chart: weighted potion output vs. foraging hours for three builds",
    href: "/blog/skyrim-alchemy/",
  },
  {
    image: "/images/mtg-distributions/complexity_creep.png",
    alt: "Chart showing Magic: The Gathering card complexity increasing over time",
    href: "/blog/mtg-distributions/",
  },
  {
    image: "/images/mtg-distributions/legendary_over_time.png",
    alt: "Chart showing the growth of legendary cards in Magic: The Gathering over time",
    href: "/blog/mtg-distributions/",
  },
];
---

<section class="carousel-section">
  <div class="carousel-wrapper">
    <div class="carousel-track" id="carousel-track">
      {FEATURED_CHARTS.map((chart) => (
        <div class="carousel-card">
          <a href={chart.href} class="card-link">
            <div class="card-image-wrapper">
              <img
                src={chart.image}
                alt={chart.alt}
                style={chart.objectPosition ? `object-position: ${chart.objectPosition}` : undefined}
              />
            </div>
            <div class="card-footer">
              <span class="read-more">Read more →</span>
            </div>
          </a>
        </div>
      ))}
    </div>
    <button class="carousel-btn prev" id="carousel-prev" aria-label="Previous chart">←</button>
    <button class="carousel-btn next" id="carousel-next" aria-label="Next chart">→</button>
  </div>
</section>

<style>
  .carousel-section {
    margin-bottom: 3em;
    padding-bottom: 2em;
    border-bottom: 1px solid var(--border);
  }

  .carousel-wrapper {
    position: relative;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 16px;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    /* right padding so the last card can scroll fully into view */
    padding-right: 4px;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-card {
    flex-shrink: 0;
    width: 460px;
    scroll-snap-align: start;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .carousel-card:hover {
    border-color: var(--accent-dark);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: var(--text);
  }

  .card-image-wrapper {
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    border-radius: 0;
    display: block;
  }

  .card-footer {
    padding: 9px 14px;
    border-top: 1px solid var(--border);
  }

  .read-more {
    font-size: 0.75em;
    color: var(--text-secondary);
    font-family: 'SF Mono', 'Fira Code', monospace;
    letter-spacing: 0.01em;
  }

  .carousel-card:hover .read-more {
    color: var(--accent-dark);
  }

  /* Arrow buttons */
  .carousel-btn {
    position: absolute;
    top: 120px; /* vertical center of the 240px image area */
    transform: translateY(-50%);
    width: 30px;
    height: 30px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 50%;
    cursor: pointer;
    font-size: 13px;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    z-index: 2;
    opacity: 1;
  }

  .carousel-btn:hover {
    border-color: var(--accent-dark);
    color: var(--accent-dark);
  }

  .carousel-btn.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .carousel-btn.prev {
    left: 8px;
  }

  .carousel-btn.next {
    right: 8px;
  }
</style>

<script>
  const track = document.getElementById("carousel-track") as HTMLElement;
  const prevBtn = document.getElementById("carousel-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("carousel-next") as HTMLButtonElement;

  const STEP = 460 + 16; // card width + gap

  function updateButtons() {
    const atStart = track.scrollLeft <= 1;
    const atEnd = track.scrollLeft >= track.scrollWidth - track.clientWidth - 1;
    prevBtn.classList.toggle("hidden", atStart);
    nextBtn.classList.toggle("hidden", atEnd);
  }

  prevBtn.addEventListener("click", () => {
    track.scrollBy({ left: -STEP, behavior: "smooth" });
  });

  nextBtn.addEventListener("click", () => {
    track.scrollBy({ left: STEP, behavior: "smooth" });
  });

  track.addEventListener("scroll", updateButtons, { passive: true });
  updateButtons();
</script>
