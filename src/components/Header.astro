---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<a href="https://github.com/ckeneha1" target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border);
		background: var(--bg);
	}
	nav {
		width: var(--content-width);
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1em 1em;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.site-title {
		font-size: 1.05em;
		font-weight: 600;
		text-decoration: none;
		color: var(--text);
		letter-spacing: -0.01em;
	}
	.site-title:hover {
		color: var(--text);
	}
	.nav-links {
		display: flex;
		gap: 1.75em;
		align-items: center;
	}
	.nav-links a {
		font-size: 0.9em;
		color: var(--text-secondary);
		text-decoration: none;
	}
	.nav-links a:hover,
	.nav-links a.active {
		color: var(--text);
	}
</style>
