---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span>&copy; {today.getFullYear()} Connor Kenehan</span>
		<div class="footer-links">
			<a href="/blog">Blog</a>
			<a href="/about">About</a>
			<a href="https://github.com/ckeneha1" target="_blank" rel="noopener noreferrer">GitHub</a>
			<a href="/rss.xml">RSS</a>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		margin-top: 4em;
	}
	.footer-inner {
		width: var(--content-width);
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1.5em 1em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.85em;
		color: var(--text-secondary);
	}
	.footer-links {
		display: flex;
		gap: 1.5em;
	}
	.footer-links a {
		color: var(--text-secondary);
		text-decoration: none;
	}
	.footer-links a:hover {
		color: var(--text);
	}
	@media (max-width: 520px) {
		.footer-inner {
			flex-direction: column;
			gap: 0.75em;
			text-align: center;
		}
	}
</style>
